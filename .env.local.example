# ── CineGPT Environment Variables ──────────────────────────
# For LOCAL dev: copy to .env.local
# For VERCEL: add these in Project Settings → Environment Variables

# GROQ — Free LLaMA 3 API (no credit card needed)
# Sign up at: https://console.groq.com  →  API Keys → Create Key
GROQ_API_KEY=your_groq_api_key_here

# TMDB — Free movie poster API
# Sign up at: https://www.themoviedb.org/settings/api
NEXT_PUBLIC_TMDB_API_KEY=your_tmdb_api_key_here
